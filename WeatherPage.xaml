<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlannerApp.WeatherPage"
             Title="WeatherPage">
    <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

        <Label 
            Text="Tryck på knappen för att hämta väder"
            FontSize="18"
            HorizontalOptions="Center" />

        <Label 
            x:Name="TempLabel"
            Text="-- °C"
            FontSize="32"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

        <Button 
            Text="Uppdatera väder"
            Clicked="OnUpdateWeatherClicked"
            HorizontalOptions="Center"
            HeightRequest="50"
            WidthRequest="200" />

    </VerticalStackLayout>
</ContentPage>