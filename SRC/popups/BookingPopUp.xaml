<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="PlannerApp.popups.BookingPopUp"
               Color="Transparent">
    
    <Border BackgroundColor="White"
            StrokeThickness="0"
            Padding="20"
            WidthRequest="400"
            HeightRequest="600">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="15"/>
        </Border.StrokeShape>
        
        <ScrollView>
            <VerticalStackLayout Spacing="20">
                <Label Text="Skapa bokning"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                
                <Label x:Name="SelectedTimeLabel"
                       FontSize="16"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                
                <HorizontalStackLayout Spacing="10">
                    <Label Text="Från:" 
                           VerticalOptions="Center"
                           TextColor="Black"
                           WidthRequest="50"/>
                    <TimePicker x:Name="StartTimePicker" 
                                Format="HH:mm"
                                HorizontalOptions="FillAndExpand"
                                TextColor="Black"/>
                </HorizontalStackLayout>
                
                <HorizontalStackLayout Spacing="10">
                    <Label Text="Till:" 
                           VerticalOptions="Center"
                           TextColor="Black"
                           WidthRequest="50"/>
                    <TimePicker x:Name="EndTimePicker" 
                                Format="HH:mm"
                                HorizontalOptions="FillAndExpand"
                                TextColor="Black"/>
                </HorizontalStackLayout>
                
                <Entry x:Name="TitleEntry"
                       Placeholder="Titel"
                       TextColor="Black"/>
                
                <Editor x:Name="DescriptionEditor"
                        Placeholder="Beskrivning"
                        HeightRequest="100"
                        TextColor="Black"/>
                
                <Label Text="välj app"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                
                <Picker x:Name="AppPicker"
                        Title="Välj en app"
                        HorizontalOptions="FillAndExpand"
                        ItemDisplayBinding="{Binding Name}"
                        TextColor="Black"
                        TitleColor="Gray"/>
                
                <Label Text="Välj färg"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Black"/>
                
                <FlexLayout x:Name="ColorPalette"
                            Wrap="Wrap"
                            JustifyContent="SpaceEvenly"
                            AlignItems="Center"
                            HeightRequest="120">
                </FlexLayout>

                <HorizontalStackLayout Spacing="15" 
                                       HorizontalOptions="End">
                    <Button Text="Avbryt" 
                            x:Name="CancelButton"
                            Clicked="OnCancelClicked"
                            BackgroundColor="LightGray"
                            TextColor="Black"
                            WidthRequest="100"/>
                    <Button Text="Spara" 
                            x:Name="SaveButton"
                            Clicked="OnSaveClicked"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            WidthRequest="100"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>