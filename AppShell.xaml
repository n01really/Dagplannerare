<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PlannerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PlannerApp"
    Title="PlannerApp">

    <TabBar>
        <ShellContent
            Title="Kalender"
            Icon="calendar.png"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Väder"
            Icon="weather.png"
            ContentTemplate="{DataTemplate local:WeatherPage}"
            Route="WeatherPage" />

        <ShellContent
            Title="Analys"
            Icon="analytics.png"
            ContentTemplate="{DataTemplate local:AnalysisPage}"
            Route="AnalysisPage" />
    </TabBar>

</Shell>
